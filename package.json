{
  "name": "localdoc",
  "version": "0.1.7",
  "description": "Offline-first documentation index for AI agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "localdoc": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "localdoc": "bun run src/cli/index.ts",
    "build": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:migrate": "DATABASE_URL=\"file:./prisma/dev.db\" bunx prisma migrate dev",
    "db:deploy": "DATABASE_URL=\"file:./prisma/dev.db\" bunx prisma migrate deploy",
    "db:generate": "bunx prisma generate",
    "db:studio": "DATABASE_URL=\"file:./prisma/dev.db\" bunx prisma studio"
  },
  "dependencies": {
    "@ai-sdk/cohere": "^4.0.12",
    "@ai-sdk/openai-compatible": "^3.0.13",
    "@chonkiejs/core": "^0.0.11",
    "@huggingface/transformers": "^4.2.0",
    "@libsql/client": "^0.17.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "^0.4.5",
    "@opentui/react": "^0.4.5",
    "@prisma/client": "^7.9.0",
    "ai": "^7.0.32",
    "chalk": "^5.6.2",
    "citty": "^0.2.2",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "linkedom": "^0.18.13",
    "p-limit": "^7.3.1",
    "p-retry": "^8.0.0",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "robots-parser": "^3.0.1",
    "sitemap": "^9.0.1",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/turndown": "^5.0.6",
    "prisma": "^7.9.0",
    "skills": "^1.5.19",
    "typescript": "^5.9.3"
  }
}
